{
  "name": "isaac-animation-viewer",
  "version": "0.2.0",
  "description": "Console Isaac asset viewer, animation explorer, and modpack builder.",
  "author": "stonedmodder",
  "main": "main/index.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build:icon": "python python/generate_app_icon.py",
    "build:win": "npm run build:icon && electron-builder --win portable"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tboi.consoleedition.viewer",
    "productName": "TMOI Console Edition",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "python/**/*",
      "assets/**/*",
      "package.json",
      "README.md",
      "isaacPS5SpritesAndAnimationsWriteup.md",
      "animationsBGbatemp.md"
    ],
    "extraMetadata": {
      "main": "main/index.cjs"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
